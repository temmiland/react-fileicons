{
	"name": "@temmiland/react-fileicons",
	"version": "2.3.1",
	"description": "A React component to use file icons more flexible.",
	"author": "temmiland",
	"keywords": [
		"react",
		"fileicons",
		"file",
		"icons"
	],
	"private": false,
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"files": [
		"dist",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/temmiland/react-fileicons.git"
	},
	"dependencies": {
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"styled-components": "^6.4.3",
		"typeface-roboto": "^1.1.13",
		"web-vitals": "^5.3.0"
	},
	"scripts": {
		"build": "rm -rf dist && NODE_ENV=production babel src --out-dir dist --copy-files"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"devDependencies": {
		"@babel/cli": "^8.0.4",
		"@babel/core": "^8.0.1",
		"@babel/preset-env": "^8.0.2",
		"@babel/preset-react": "^8.0.1",
		"nth-check": "^3.0.1",
		"prop-types": "^15.8.1"
	}
}
